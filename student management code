# Student Management System
# Python + SQLite

import sqlite3
import pandas as pd
connection = sqlite3.connect("student_database.db")
cursor = connection.cursor()
cursor.execute("""
CREATE TABLE IF NOT EXISTS students(
    id INTEGER PRIMARY KEY,
    name TEXT,
    age INTEGER,
    department TEXT,
    email TEXT
)
""")

connection.commit()

def add_student():

    id = int(input("Enter Student ID: "))
    name = input("Enter Name: ")
    age = int(input("Enter Age: "))
    department = input("Enter Department: ")
    email = input("Enter Email: ")

    cursor.execute(
        """
        INSERT INTO students
        VALUES(?,?,?,?,?)
        """,
        (id, name, age, department, email)
    )

    connection.commit()

    print("Student Added Successfully\n")

def view_students():

    data = pd.read_sql_query(
        "SELECT * FROM students",
        connection
    )

    print("\nStudent Details")
    print(data)
    print()

def search_student():

    name = input("Enter Student Name: ")

    data = pd.read_sql_query(
        f"""
        SELECT * FROM students
        WHERE name='{name}'
        """,
        connection
    )

    print(data)
    print()

def update_student():

    id = int(input("Enter Student ID: "))
    age = int(input("Enter New Age: "))

    cursor.execute(
        """
        UPDATE students
        SET age=?
        WHERE id=?
        """,
        (age,id)
    )

    connection.commit()

    print("Student Updated Successfully\n")


def delete_student():

    id = int(input("Enter Student ID: "))

    cursor.execute(
        """
        DELETE FROM students
        WHERE id=?
        """,
        (id,)
    )

    connection.commit()

    print("Student Deleted Successfully\n")

while True:

    print(" Student Management System 

1. Add Student
2. View Students
3. Search Student
4. Update Student
5. Delete Student
6. Exit")

    choice = int(input("Enter your choice: "))


    if choice == 1:
        add_student()

    elif choice == 2:
        view_students()

    elif choice == 3:
        search_student()

    elif choice == 4:
        update_student()

    elif choice == 5:
        delete_student()

    elif choice == 6:
        print("Thank You!")
        break

    else:
        print("Invalid Choice")
